{
  "name": "SMS Gammu Gateway",
  "version": "1.7.1",
  "slug": "sms_gammu_gateway",
  "description": "SMS gateway for USB GSM modems (SIM800L, Huawei, Quectel, etc.) with REST API, MQTT integration and Home Assistant auto-discovery. Send/receive SMS, Flash SMS support, signal and network monitoring, incoming and missed call detection, SMS cost tracking. Web UI with Swagger documentation.",
  "startup": "services",
  "arch": ["amd64", "i386", "aarch64", "armv7", "armhf"],
  "boot": "auto",
  "panel_icon": "mdi:cellphone-message",
  "url": "https://github.com/PavelVe/home-assistant-addons/blob/main/sms-gammu-gateway/README.md",
  "homeassistant": "2022.1.1",
  "options": {
    "device_path": "/dev/ttyUSB0",
    "modem_baud_rate": "115200",
    "urc_filter_enabled": true,
    "pin": "",
    "ssl": false,
    "username": "admin",
    "password": "password",
    "mqtt_enabled": true,
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "mqtt_topic_prefix": "homeassistant/sensor/sms_gateway",
    "mqtt_device_id": "sms_gateway",
    "sms_monitoring_enabled": true,
    "sms_check_interval": 60,
    "sms_cost_per_message": 0.0,
    "sms_cost_currency": "CZK",
    "auto_delete_read_sms": true,
    "sms_delete_delay_seconds": 0,
    "missed_calls_monitoring_enabled": true,
    "incoming_call_auto_reset_seconds": 60,
    "voice_call_enabled": false
  },
  "schema": {
    "device_path": "str",
    "modem_baud_rate": "match(^(auto|[0-9]+)$)",
    "urc_filter_enabled": "bool",
    "pin": "password?",
    "ssl": "bool",
    "username": "str",
    "password": "password",
    "mqtt_enabled": "bool",
    "mqtt_host": "str",
    "mqtt_port": "int(1,65535)",
    "mqtt_username": "str?",
    "mqtt_password": "password?",
    "mqtt_topic_prefix": "str",
    "mqtt_device_id": "match(^[a-z0-9_]+$)?",
    "sms_monitoring_enabled": "bool",
    "sms_check_interval": "int(10,300)",
    "sms_cost_per_message": "float?",
    "sms_cost_currency": "str",
    "auto_delete_read_sms": "bool",
    "sms_delete_delay_seconds": "int(0,300)",
    "missed_calls_monitoring_enabled": "bool",
    "incoming_call_auto_reset_seconds": "int(10,300)",
    "voice_call_enabled": "bool"
  },
  "ingress": true,
  "ingress_port": 5000,
  "host_network": false,
  "devices": ["/dev/ttyUSB0:/dev/ttyUSB0:rwm", "/dev/ttyUSB1:/dev/ttyUSB1:rwm", "/dev/ttyUSB2:/dev/ttyUSB2:rwm", "/dev/ttyUSB3:/dev/ttyUSB3:rwm", "/dev/ttyUSB4:/dev/ttyUSB4:rwm", "/dev/ttyUSB5:/dev/ttyUSB5:rwm", "/dev/ttyACM0:/dev/ttyACM0:rwm", "/dev/ttyACM1:/dev/ttyACM1:rwm", "/dev/ttyACM2:/dev/ttyACM2:rwm", "/dev/ttyACM3:/dev/ttyACM3:rwm", "/dev/ttyAMA0:/dev/ttyAMA0:rwm", "/dev/ttyAMA1:/dev/ttyAMA1:rwm", "/dev/ttyS0:/dev/ttyS0:rwm"],
  "privileged": ["SYS_RAWIO"],
  "udev": true,
  "init": false,
  "ports": {
    "5000/tcp": 5000
  },
  "ports_description": {
    "5000/tcp": "SMS Gateway API port"
  }
}